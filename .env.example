# ─── MongoDB Connection ────────────────────────────────────────────────────────
# Get this from MongoDB Atlas:
#   Database > Connect > Drivers > Copy the connection string
#   Replace <username>, <password>, and <cluster> with your actual values.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# The database name that will be created inside your cluster.
# All collections will live under this database.
MONGODB_DB_NAME=qa_tracker

# ─── Collection Names ──────────────────────────────────────────────────────────
# These are optional. The defaults (shown below) are used if not set.
# Only add these if you want to use different collection names.
# MONGODB_COLLECTION_USERS=users
# MONGODB_COLLECTION_TASKS=tasks
# MONGODB_COLLECTION_QA_LOGS=qa_logs
# MONGODB_COLLECTION_STATUS_HISTORY=status_history
# MONGODB_COLLECTION_ASSIGNMENT_HISTORY=assignment_history
